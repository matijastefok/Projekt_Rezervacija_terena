@model IEnumerable<Projekt_Rezervacija_terena.Models.Rezervacija>

@{
    ViewData["Title"] = "Admin Panel - Pregled svih rezervacija";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-dark">Sustav za upravljanje terminima</h1>
            <p class="text-muted">Pregled i upravljanje rezervacijama svih registriranih korisnika.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Natrag na početnu</a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card bg-primary text-white border-0 shadow-sm p-3">
                <div class="card-body">
                    <h5 class="card-title text-white-50">Ukupno rezervacija</h5>
                    <h2 class="fw-bold mb-0">@Model.Count()</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white border-0 shadow-sm p-3">
                <div class="card-body">
                    <h5 class="card-title text-white-50">Teniski termini</h5>
                    <h2 class="fw-bold mb-0">@Model.Count(r => r.Sport == "Tenis")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white border-0 shadow-sm p-3">
                <div class="card-body">
                    <h5 class="card-title text-white-50">Nogomet & Košarka</h5>
                    <h2 class="fw-bold mb-0">@Model.Count(r => r.Sport == "Nogomet" || r.Sport == "Košarka")</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm p-4">
        <h3 class="fw-bold mb-3">Sve aktivne rezervacije u sustavu</h3>
        <div class="table-responsive">
            <table class="table align-middle table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Korisnik</th>
                        <th>Sport</th>
                        <th>Datum</th>
                        <th>Vrijeme</th>
                        <th class="text-end">Upravljanje</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var rezervacija in Model)
                        {
                            <tr>
                                <td><span class="badge bg-secondary px-3 py-2 fs-6">@rezervacija.KorisnikIme</span></td>
                                <td><strong>@rezervacija.Sport</strong></td>
                                <td>@rezervacija.Datum.ToString("dd.MM.yyyy")</td>
                                <td>@rezervacija.Vrijeme.ToString(@"hh\:mm") h</td>
                                <td class="text-end">
                                    <form asp-action="OtkaziBiloKojuRezervaciju" method="post" class="d-inline" onsubmit="return confirm('Pažnja! Želite li trajno obrisati rezervaciju ovog korisnika?');">
                                        <input type="hidden" name="id" value="@rezervacija.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm px-3">Ukloni termin</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Trenutno nema niti jedne rezervacije u sustavu.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
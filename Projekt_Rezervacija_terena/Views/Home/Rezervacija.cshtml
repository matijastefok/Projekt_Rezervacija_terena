@{
    ViewData["Title"] = "Rezervacija Termina";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Detalji rezervacije</h4>
                </div>
                <div class="card-body">
                    <form method="post" novalidate>
                        <div class="mb-3">
                            <label class="form-label">Odaberi sport</label>
                            <select class="form-select">
                                <option>Tenis</option>
                                <option>Nogomet</option>
                                <option>Košarka</option>
                                <option>Stolni tenis</option>
                                <option>Odbojka</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Datum termina</label>
                            <input type="date" class="form-control" id="datumInput" />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Odaberite vrijeme</label>
                            <input type="time" class="form-control" id="vrijemeInput" />
                        </div>

                        <div class="alert alert-info">
                            Ukupno za platiti: <strong>12.00 €</strong>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Potvrdi rezervaciju</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-link w-100 mt-2 text-muted">Odustani</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var forma = document.querySelector("form");
        var datumPolje = document.getElementById("datumInput");
        var vrijemePolje = document.getElementById("vrijemeInput");

        if (forma) {
            forma.addEventListener("submit", function (event) {
                var ispravno = true;

                if (!datumPolje.value) {
                    ispravno = false;
                    prikažiGrešku(datumPolje, "datumGreska", "Upišite točan datum termina.");
                }

                if (!vrijemePolje.value) {
                    ispravno = false;
                    prikažiGrešku(vrijemePolje, "vrijemeGreska", "Upišite točno vrijeme termina.");
                }

                if (!ispravno) {
                    event.preventDefault();
                }
            });
        }

        function prikažiGrešku(polje, greskaId, poruka) {
            var staraPoruka = document.getElementById(greskaId);
            if (!staraPoruka) {
                var greskaNatpis = document.createElement("span");
                greskaNatpis.id = greskaId;
                greskaNatpis.style.color = "red";
                greskaNatpis.style.display = "block";
                greskaNatpis.style.marginTop = "5px";
                greskaNatpis.style.fontSize = "14px";
                greskaNatpis.innerText = poruka;
                polje.parentNode.appendChild(greskaNatpis);
            }
        }

        datumPolje.addEventListener("input", function () {
            var staraPoruka = document.getElementById("datumGreska");
            if (staraPoruka) staraPoruka.remove();
        });

        vrijemePolje.addEventListener("input", function () {
            var staraPoruka = document.getElementById("vrijemeGreska");
            if (staraPoruka) staraPoruka.remove();
        });
    });
</script>
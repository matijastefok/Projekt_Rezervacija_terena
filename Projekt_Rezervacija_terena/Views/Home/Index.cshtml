@model IEnumerable<Projekt_Rezervacija_terena.Models.Rezervacija>

@{
    ViewData["Title"] = "Početna - Rezervacija Sportskih Terena";
}

<style>
    .hover-shadow {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-shadow:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .border-dashed {
        border-style: dashed !important;
        border-width: 2px;
    }
</style>

<div id="main-content">
    <div class="p-5 mb-4 bg-dark text-white rounded-3 shadow text-center">
        <div class="container-fluid py-5">
            <h1 class="display-4 fw-bold">Pronađi i rezerviraj svoj teren</h1>
            <p class="fs-4">Jednostavan pregled i organizacija sportskih termina na jednom mjestu.</p>
            <a href="#tereni" class="btn btn-primary btn-lg px-5 shadow-sm">Kreni s rezervacijom</a>
        </div>
    </div>

    <div id="tereni" class="container py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Dostupni sportski tereni</h2>
            <div class="mx-auto" style="width: 80px; height: 4px; background: #0d6efd; border-radius: 2px;"></div>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow">
                    <div class="card-header bg-success text-white text-center py-3">
                        <h4 class="mb-0">Tenis</h4>
                    </div>
                    <div class="card-body text-center">
                        <p class="text-muted small">Vanjski i unutarnji tereni sa zemljom.</p>
                        <h5 class="fw-bold mb-3">12.00 € / sat</h5>
                        <button onclick="prikaziRezervaciju('Tenis')" class="btn btn-outline-success w-100 fw-bold">Rezerviraj tenis</button>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow">
                    <div class="card-header bg-primary text-white text-center py-3">
                        <h4 class="mb-0">Nogomet</h4>
                    </div>
                    <div class="card-body text-center">
                        <p class="text-muted small">Umjetna trava vrhunske kvalitete.</p>
                        <h5 class="fw-bold mb-3">35.00 € / sat</h5>
                        <button onclick="prikaziRezervaciju('Nogomet')" class="btn btn-outline-primary w-100 fw-bold">Rezerviraj nogomet</button>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow">
                    <div class="card-header bg-warning text-dark text-center py-3">
                        <h4 class="mb-0">Košarka</h4>
                    </div>
                    <div class="card-body text-center">
                        <p class="text-muted small">Dvorana s profesionalnim parketom.</p>
                        <h5 class="fw-bold mb-3">25.00 € / sat</h5>
                        <button onclick="prikaziRezervaciju('Košarka')" class="btn btn-outline-warning w-100 fw-bold text-dark">Rezerviraj košarku</button>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-dashed shadow-sm bg-light">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                        <h5 class="text-muted mt-3">Administrator ste?</h5>
                        <p class="small text-muted">Upravljanje sportskim terenima.</p>

                        @if (Context.Session.GetString("KorisnikEmail") == "admin@primjer.com")
                        {
                            <a asp-action="Admin" class="btn btn-dark btn-sm px-4 shadow">Otvori Admin Panel</a>
                        }
                        else
                        {
                            <button onclick="alert('Morate se prijaviti s administratorskim računom (admin@primjer.com) da biste pristupili panelu.');" class="btn btn-secondary btn-sm px-4" disabled>Admin Panel</button>
                        }
                    </div>
                </div>
            </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-light py-5">
        <div class="container">
            <h3 class="fw-bold mb-4 text-center">Moje aktivne rezervacije</h3>
            <div class="card border-0 shadow-sm p-4">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Sport</th>
                                <th>Datum</th>
                                <th>Vrijeme</th>
                                <th>Status</th>
                                <th class="text-end">Akcija</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var rezervacija in Model)
                                {
                                    <tr>
                                        <td><strong>@rezervacija.Sport</strong></td>
                                        <td>@rezervacija.Datum.ToString("dd.MM.yyyy")</td>
                                        <td>@rezervacija.Vrijeme.ToString(@"hh\:mm") h</td>
                                        <td><span class="badge rounded-pill bg-success">Potvrđeno</span></td>
                                        <td class="text-end">
                                            <form asp-action="OtvaziRezervaciju" method="post" class="d-inline" onsubmit="return confirm('Jeste li sigurni da želite otkazati ovaj termin?');">
                                                <input type="hidden" name="id" value="@rezervacija.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Otkaži</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">
                                        Nemate aktivnih rezervacija.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="reservation-form" class="container mt-5 d-none">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white p-4">
                    <h3 class="mb-0 text-center">Nova rezervacija</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Rezerviraj" method="post" id="formaRezervacija" novalidate>
                        <div class="mb-3 text-center">
                            <h4 id="prikaz-sporta" class="text-primary fw-bold"></h4>
                            <input type="hidden" id="input-sport" name="Sport" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Datum termina</label>
                            <input name="Datum" id="datumInput" type="date" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Odaberite vrijeme</label>
                            <input name="Vrijeme" id="vrijemeInput" type="time" class="form-control" />
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 shadow">Potvrdi rezervaciju</button>
                        <button type="button" onclick="zatvoriRezervaciju()" class="btn btn-link w-100 mt-2 text-muted text-decoration-none">Odustani</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function prikaziRezervaciju(sport) {
        document.getElementById('main-content').classList.add('d-none');
        document.getElementById('reservation-form').classList.remove('d-none');

        document.getElementById('prikaz-sporta').innerText = "Teren: " + sport;
        document.getElementById('input-sport').value = sport;

        window.scrollTo(0, 0);
    }

    function zatvoriRezervaciju() {
        document.getElementById('main-content').classList.remove('d-none');
        document.getElementById('reservation-form').classList.add('d-none');
    }

    document.addEventListener("DOMContentLoaded", function () {
        var forma = document.getElementById("formaRezervacija");
        var datumPolje = document.getElementById("datumInput");
        var vrijemePolje = document.getElementById("vrijemeInput");

        if (forma) {
            forma.addEventListener("submit", function (event) {
                var ispravno = true;

                if (!datumPolje.value) {
                    ispravno = false;
                    prikažiGrešku(datumPolje, "datumGreska", "Upišite točan datum termina.");
                }

                if (!vrijemePolje.value) {
                    ispravno = false;
                    prikažiGrešku(vrijemePolje, "vrijemeGreska", "Upišite točno vrijeme termina.");
                }

                if (!ispravno) {
                    event.preventDefault(); 
                }
            });
        }

        function prikažiGrešku(polje, greskaId, poruka) {
            var staraPoruka = document.getElementById(greskaId);
            if (!staraPoruka) {
                var greskaNatpis = document.createElement("span");
                greskaNatpis.id = greskaId;
                greskaNatpis.style.color = "red";
                greskaNatpis.style.display = "block";
                greskaNatpis.style.marginTop = "5px";
                greskaNatpis.style.fontSize = "14px";
                greskaNatpis.innerText = poruka;
                polje.parentNode.appendChild(greskaNatpis);
            }
        }

        if (datumPolje) {
            datumPolje.addEventListener("input", function () {
                var staraPoruka = document.getElementById("datumGreska");
                if (staraPoruka) staraPoruka.remove();
            });
        }

        if (vrijemePolje) {
            vrijemePolje.addEventListener("input", function () {
                var staraPoruka = document.getElementById("vrijemeGreska");
                if (staraPoruka) staraPoruka.remove();
            });
        }
    });
</script>
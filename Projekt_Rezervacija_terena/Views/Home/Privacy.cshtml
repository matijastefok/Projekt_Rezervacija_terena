@{
    ViewData["Title"] = "O projektu";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm border-0 p-4 bg-light">
                <h1 class="text-primary border-bottom pb-2">@ViewData["Title"]</h1>

                <p class="lead mt-3">
                    Ova web aplikacija napravljena je kao dio projektnog zadatka.
                </p>

                <h4 class="mt-4 text-secondary">Cilj projekta</h4>
                <p>
                    Glavna svrha web aplikacije je omogućiti korisnicima jednostavan pregled i brzu rezervaciju
                    sportskih terena na jednom mjestu.
                </p>

                <h4 class="mt-4 text-secondary">Ključne funkcionalnosti sustava:</h4>
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item bg-transparent"><i class="bi bi-check-circle-fill text-success me-2"></i> Registracija i prijava korisnika</li>
                    <li class="list-group-item bg-transparent"><i class="bi bi-check-circle-fill text-success me-2"></i> Upravljanje sportskim terenima</li>
                    <li class="list-group-item bg-transparent"><i class="bi bi-check-circle-fill text-success me-2"></i> Pregled dostupnih termina u realnom vremenu</li>
                    <li class="list-group-item bg-transparent"><i class="bi bi-check-circle-fill text-success me-2"></i> Rezervacija odabranog sportskog terena</li>
                    <li class="list-group-item bg-transparent"><i class="bi bi-check-circle-fill text-success me-2"></i> Pregled i otkazivanje vlastitih rezervacija</li>
                </ul>

                <div class="alert alert-info border-0 shadow-sm">
                    <strong>Napomena:</strong> Sustav koristi ASP.NET Core MVC arhitekturu s Bootstrap sučeljem
                    kako bi se stranica prilagođavala ekranu.
                </div>
            </div>
        </div>
    </div>
</div>